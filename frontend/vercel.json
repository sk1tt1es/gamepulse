{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://gamepulse-backend.fly.dev/api/:path*"
    },
    {
      "source": "/sms/:path*",
      "destination": "https://gamepulse-backend.fly.dev/sms/:path*"
    }
  ]
}
