# GamePulse environment variables — TEMPLATE.
#
# Copy this file to `.env` (which is gitignored) and fill in real values.
# NEVER put real API keys or secrets in this template file — it is
# committed to source control and visible to anyone with repo access.
#
# Anything left blank causes the backend to fall back to bundled mock
# providers, which keeps the demo runnable end-to-end without any
# external accounts.

# --- Server ---
HTTP_ADDR=:8080
DATABASE_URL=postgres://gamepulse:gamepulse@localhost:5432/gamepulse?sslmode=disable
ENABLE_WORKERS=true

# --- Worker tuning ---
LIVE_TRACKER_INTERVAL=8s
NEWS_AGGREGATOR_INTERVAL=15m
DIGEST_INTERVAL=1m

# --- Sports data provider ---
# "espn" = real ESPN public scoreboard (default, no key required)
# "mock" = deterministic simulator for offline / demo
SPORTS_PROVIDER=espn

# --- News provider (NewsAPI.org) ---
# Get a key at https://newsapi.org/register
NEWS_API_KEY=

# --- AI summariser (OpenAI Chat Completions) ---
# Get a key at https://platform.openai.com/api-keys
AI_API_KEY=

# --- SMS provider (Twilio) ---
# Get credentials at https://console.twilio.com — the FROM_NUMBER must
# be a Twilio number you own; for US production traffic it must be
# registered under an A2P 10DLC campaign.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
